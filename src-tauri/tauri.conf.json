{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "retermina",
  "version": "0.2.1",
  "identifier": "com.retermina.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "retermina",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/matthewhamilton3141/Retermina/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzMDNCOTU4QTJGOTMyMjYKUldRbU12bWlXTGtEOHhxYnQ1b3lMTzJrL01jQi91S1FLYjhpckxyTUFqbk1CZGZwYVA5NUZSTGQK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
